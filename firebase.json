{
  "hosting": {
    "target": "revival-site",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/about", "destination": "/index.html" },
      { "source": "/details", "destination": "/index.html" },
      { "source": "/register", "destination": "/index.html" },
      { "source": "/countdown", "destination": "/index.html" },
      { "source": "/vault", "destination": "/vault.html" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Access-Control-Allow-Origin",
            "value": "*"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }, {
  "key": "Vary",
  "value": "User-Agent"
}

        ]
      }
    ]
  }
}