{
  "hosting": {
    "target": "revival-site",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/about", "destination": "/index.html" },
      { "source": "/details", "destination": "/index.html" },
      { "source": "/register", "destination": "/index.html" },
      { "source": "/countdown", "destination": "/index.html" },
      { "source": "/vault", "destination": "/vault.html" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
      "source": "**/*.png",
      "headers": [
        {
          "key": "Content-Type",
          "value": "image/png"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        }
      ]
    }
    ]
  }
}